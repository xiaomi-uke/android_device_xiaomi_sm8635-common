type vendor_pen_events, domain;
type vendor_pen_events_exec, exec_type, vendor_file_type, file_type;

init_daemon_domain(vendor_pen_events)

allow vendor_pen_events vendor_file:file rx_file_perms;
allow vendor_pen_events proc:file r_file_perms;
allow vendor_pen_events input_device:chr_file { rw_file_perms unlink };
allow vendor_pen_events input_device:dir create_dir_perms;
allow vendor_pen_events vendor_toolbox_exec:file rx_file_perms;
